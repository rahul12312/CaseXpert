{
  "name": "casexpert-backend",
  "version": "1.0.0",
  "description": "Node.js backend for CaseXpert with Express + MongoDB + Mongoose + JWT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill-port": "FOR /F \"tokens=5\" %P IN ('netstat -ano ^| findstr :5000') DO taskkill /PID %P /F",
    "clean-start": "npm run kill-port & npm start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "legal",
    "casexpert"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "groq-sdk": "^0.37.0",
    "i18n": "^0.15.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.2",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "openai": "^6.9.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.13.0",
    "rss-parser": "^3.13.0",
    "socket.io": "^4.8.3",
    "twilio": "^5.13.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
